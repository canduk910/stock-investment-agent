# 이미지 빌드 컨텍스트 제외 목록(dev Dockerfile.dev + prod Dockerfile 공용).
# prod 는 frontend/ 소스가 필요(멀티스테이지 stage1 에서 vite build) → frontend 전체 제외 금지.
# 대신 무거운/재생성 산출물만 골라 제외한다.

# 시크릿 — 이미지에 굽지 않는다(런타임 env/Secret Manager 주입).
.env
.env.local

# 의존성·빌드 산출물(컨테이너에서 재생성; prod 는 dist 를 stage1 에서 새로 빌드).
.venv
node_modules
frontend/node_modules
frontend/dist
.vite
**/__pycache__
**/*.pyc
.pytest_cache

# 런타임 캐시·사용자데이터·저작물(이미지 미포함).
.cache
reports

# VCS·에디터·문서·작업기록.
.git
.gitignore
.dockerignore
.gcloudignore
.DS_Store
_workspace
.claude
*.md
