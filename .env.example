# 한국투자증권(KIS) Open API — 홈페이지에서 발급
KIS_APP_KEY=
KIS_APP_SECRET=
# 환경 구분: real(실전) | demo(모의)
KIS_ENV=real
# 계좌번호 (잔고 조회용, 실연동 시 필요)
KIS_ACCOUNT_NO=
# 잔고(포트폴리오) 조회 — 계좌번호 앞 8자리(CANO). 미설정 시 KIS_ACCOUNT_NO 로 폴백
KIS_ACNT_NO=
# 잔고 조회 상품코드(국내주식 종합계좌). 미설정 시 "01"
KIS_ACNT_PRDT_CD_STK=

# FRED (거시 지표) — https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=

# DART (재무·공시) — 선택. W08 재무는 KIS 재무 API로 대체함(W09 P2 보강용)
DART_API_KEY=

# OpenAI (W09 LLM 챗봇) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ── 유저베이스(인증·DB) ──
# DB 연결 URL. 미설정 시 로컬 SQLite(sqlite:///.cache/app.db). 프로덕션(GCP)은 Cloud SQL Postgres:
#   postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=
# JWT 서명 시크릿(≥32바이트 랜덤). 프로덕션 필수 — 미설정 시 개발용 기본값(비보안).
#   예: openssl rand -hex 32
JWT_SECRET=
